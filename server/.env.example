# Server environment example (no secrets)
PORT=4000
MONGODB_URI="mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/athenadb?retryWrites=true&w=majority&appName=<YourAppName>"
JWT_SECRET=change_me

# Optional integrations (leave blank if unused)
GEMINI_API_KEY=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
